FROM ubuntu:20.04
ENV DEBIAN_FRONTEND=noninteractive

# 1. Устанавливаем инструменты (В Ubuntu 20.04 они идеальны для vcpkg)
RUN apt-get update && apt-get install -y git cmake g++ gcc pkg-config build-essential wget curl zip unzip tar autoconf automake libtool linux-libc-dev

# 2. Build vcpkg
RUN git clone https://github.com/microsoft/vcpkg.git /opt/vcpkg
RUN /opt/vcpkg/bootstrap-vcpkg.sh
RUN /opt/vcpkg/vcpkg integrate install

# 3. Custom static triplet
COPY scripts/triplets /opt/vcpkg-custom-triplets
ENV VCPKG_OVERLAY_TRIPLETS=/opt/vcpkg-custom-triplets

# ==============================================================================
# БРОНЕБОЙНОЕ КЭШИРОВАНИЕ
# ==============================================================================
RUN /opt/vcpkg/vcpkg install protobuf abseil utf8-range --triplet x64-linux-static
RUN /opt/vcpkg/vcpkg install boost-property-tree boost-json boost-filesystem boost-iostreams --triplet x64-linux-static
RUN /opt/vcpkg/vcpkg install boost-program-options boost-crc boost-math boost-format boost-test --triplet x64-linux-static

# ==============================================================================
# СПАСАЕМ КЭШ: Добавляем bison и flex (они нужны для компиляции исходников Kerberos!)
# ==============================================================================
RUN apt-get update && apt-get install -y autoconf-archive bison flex gettext python3

# ВОТ ОНО: Теперь Kerberos соберется до конца!
RUN /opt/vcpkg/vcpkg install snappy fmt curl cyrus-sasl --triplet x64-linux-static

# ПАТЧ: Явно включаем поддержку SSL, SASL и сжатия в движке Kafka
RUN /opt/vcpkg/vcpkg install "librdkafka[core,ssl,sasl,zlib,zstd]" --triplet x64-linux-static
RUN /opt/vcpkg/vcpkg install avro-cpp --triplet x64-linux-static

# ВАЖНО: avro-cpp ОБЯЗАН быть >= 1.12.1. В версиях ниже (подтверждено на 1.11.3) — краш
# (segfault / vector range_check) при декодировании глубоко-вложенных рекурсивных Avro-схем
# (напр. VariantItemMessage с рекурсивным Node глубины 38). В 1.12.1 исправлено. Гейтим сборку.
RUN V=$(/opt/vcpkg/vcpkg list avro-cpp | awk '{print $2}' | head -1); \
    echo "avro-cpp version: $V"; \
    case "$V" in \
      1.12.1*|1.12.2*|1.12.[3-9]*|1.1[3-9].*|2.*) echo "avro-cpp OK ($V)";; \
      *) echo "ERROR: avro-cpp $V имеет баг декодирования рекурсивных схем, нужно >= 1.12.1" >&2; exit 1;; \
    esac

# ==============================================================================
# ШАГ 3: Зависимость для 1С (генерация UUID)
# ==============================================================================
RUN apt-get install -y uuid-dev

# Final build of the project (SimpleKafka1C)
COPY . /src
WORKDIR /src

# ПАТЧ: Удаляем виндовый кэш CMake, который скопировался с хоста
RUN rm -rf build CMakeCache.txt

# ПАТЧ: Мгновенно обновляем CMake до новейшей версии через Python (т.к. в Ubuntu 20.04 встроен старый 3.16)
RUN apt-get update && apt-get install -y python3-pip && pip3 install cmake --upgrade

# Собираем проект свежим CMake
# ПАТЧ: Прикрепляем статические библиотеки криптографии и авторизации к финальной .so компоненте
RUN cmake -B build -G "Unix Makefiles" -DCMAKE_TOOLCHAIN_FILE=/opt/vcpkg/scripts/buildsystems/vcpkg.cmake -DVCPKG_TARGET_TRIPLET=x64-linux-static -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_STANDARD_LIBRARIES="-L/opt/vcpkg/installed/x64-linux-static/lib -lzstd -llzma -lbz2 -lsnappy -lssl -lcrypto -lsasl2 -lgssapi_krb5 -lkrb5 -lk5crypto -lcom_err -lresolv -ldl -lpthread" .
RUN cmake --build build --config Release